# .gitignore

# ─────────────────────────────────────────────────────────────────────────────
# Environment files — NICIODATA in Git
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.development

# ─────────────────────────────────────────────────────────────────────────────
# Next.js
# ─────────────────────────────────────────────────────────────────────────────
.next/
out/
build/

# ─────────────────────────────────────────────────────────────────────────────
# Node.js
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────────────────────
# IDE / Editor
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─────────────────────────────────────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────────────────────────────────────
.dockerignore
